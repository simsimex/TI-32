# Copy this file to `.env` (in the server/ directory) and fill in real values.
# Do NOT commit your real .env to git.
# (When deploying on Render, set these in the dashboard instead of a file.)

# Port the server listens on. Render sets this for you to 10000; locally
# anything works (e.g. 8080). The ESP32's SERVER in secrets.h must match.
PORT=10000

# Anthropic API key — required. Used by /gpt/ask and /gpt/solve.
# Get one from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: pin a specific Claude model. Defaults to claude-sonnet-4-5.
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: OpenAI API key. Only needed if you opt into OpenAI below.
# OPENAI_API_KEY=sk-...

# Optional: route everything to OpenAI gpt-4o instead of Claude.
# USE_OPENAI=1
# Or just one route:
# USE_OPENAI_FOR_ASK=1
# USE_OPENAI_FOR_SOLVE=1
