# Copy this file to `.env` (in the server/ directory) and fill in real values.
# Do NOT commit your real .env to git.

# Port the server listens on. The ESP32's SERVER setting in secrets.h must
# match this (e.g. SERVER="http://192.168.1.42:8080").
PORT=8080

# Anthropic API key — used by the patched /gpt/solve route for Claude vision.
# Get one from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: pin a specific Claude model. Defaults to claude-sonnet-4-5.
# ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI API key — used by the original /gpt/ask text route. Still required
# unless you also patch /ask to use Claude.
OPENAI_API_KEY=sk-...

# Set to "1" to use OpenAI gpt-4o for /gpt/solve instead of Claude.
# USE_OPENAI_FOR_SOLVE=1
